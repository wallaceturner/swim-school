{
  "id": "swim-school",
  "name": "Swim School",
  "description": "WhatsApp bot for swim school instructors: document queries.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "instructors": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "instructorId": { "type": "string" },
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "siteId": { "type": "string" }
          },
          "required": ["instructorId", "name", "phone", "siteId"]
        }
      },
      "sites": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "siteId": { "type": "string" },
            "name": { "type": "string" },
            "suburb": { "type": "string" },
            "managerPhone": { "type": "string" },
            "managerName": { "type": "string" }
          },
          "required": ["siteId", "name", "managerPhone", "managerName"]
        }
      },
      "driveFolder": {
        "type": "string",
        "default": "instructors"
      },
      "apiMode": {
        "type": "string",
        "enum": ["mock", "live"],
        "default": "mock"
      },
      "apiBaseUrl": {
        "type": "string"
      },
      "coverRequestExpiryHours": {
        "type": "number",
        "default": 24
      }
    }
  }
}
