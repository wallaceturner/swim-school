{
  "id": "swim-school",
  "name": "Swim School",
  "description": "WhatsApp bot for swim school instructors: document queries.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "instructors": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "siteIds": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["name", "phone", "email", "siteIds"]
        }
      },
      "managers": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string" },
            "siteIds": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["name", "phone", "email", "siteIds"]
        }
      },
      "sites": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "siteId": { "type": "string" }
          },
          "required": ["siteId"]
        }
      },
      "driveFolder": {
        "type": "string",
        "default": "instructors"
      },
      "apiMode": {
        "type": "string",
        "enum": ["mock", "live"],
        "default": "mock"
      },
      "apiBaseUrl": {
        "type": "string"
      },
      "coverRequestExpiryHours": {
        "type": "number",
        "default": 24
      }
    }
  }
}
